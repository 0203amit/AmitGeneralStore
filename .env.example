# Google OAuth 2.0 Client ID (from Google Cloud Console → APIs & Services → Credentials)
VITE_GOOGLE_CLIENT_ID=902226654882-d84pl7ere9hhio3s68ses3b355heoe37.apps.googleusercontent.com

# Google Cloud Project Number (from Google Cloud Console → Project Settings)
VITE_GOOGLE_PROJECT_NUMBER=902226654882

# Show admin login form (username/password) alongside Google sign-in
VITE_ADMIN_LOGIN_ENABLED=true

# --- Server-only variables (set in Vercel dashboard, NOT prefixed with VITE_) ---
# These are used by the api/verify-admin.js serverless function and are
# NEVER exposed to the browser.
#
# SA_CLIENT_EMAIL=admin-login@your-project.iam.gserviceaccount.com
# SA_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# SA_SPREADSHEET_ID=<spreadsheet-id-from-google-sheets-url>
